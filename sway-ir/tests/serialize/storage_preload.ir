// regex: VAR=v\d+v\d+

script {
// check: fn main
    fn main() -> u64 {
        local b256 key_for_x

        entry():
        v0 = get_local __ptr b256, key_for_x
        v1 = const b256 0x7fbd1192666bfac3767b890bd4d048c940879d316071e20c7c8c81bce2ca41c5
        store v1 to v0
// check: $VAR = state_preload key $VAR
        v3 = state_preload key v0

        ret u64 v3
    }
}
