script {
    entry fn main() -> () {
        local b256 tmp

        entry():
        v0 = const bool false
        v1 = const bool true
        v2 = call c(v0, v1)
        v3 = get_local __ptr b256, tmp
        store v2 to v3
        v4 = const unit ()
        ret () v4
    }

    fn c(p: bool, q: bool) -> b256 {
        entry(p: bool, q: bool):
        cbr p, block0(), block1()

        block0():
        v0 = call a()
        br block5(v0)

        block1():
        cbr q, block2(), block3()

        block2():
        v1 = call a()
        br block5(v1)

        block3():
        v2 = call b()
        br block5(v2)

        block5(v3: b256):
        ret b256 v3
    }

    fn a() -> b256 {
        local b256 twobee = const b256 0x2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b

        entry():
        v0 = get_local __ptr b256, twobee
        v1 = load v0
        ret b256 v1
    }

    fn b() -> b256 {
        local b256 dada = const b256 0xdadadadadadadadadadadadadadadadadadadadadadadadadadadadadadadada

        entry():
        v0 = get_local __ptr b256, dada
        v1 = load v0
        ret b256 v1
    }
}
