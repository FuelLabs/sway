script {
    fn test1(p: u64) -> u64 {
        entry(p: u64):
        v0 = const u64 100
        v2 = cmp eq v0 p
        cbr v2, get_0_block0(), get_0_block1()

        get_0_block0():
        v5 = const u64 1
        v6 = add v5, p
        ret u64 v6

        get_0_block1():
        v7 = const u64 111
        v8 = add v7, p
        ret u64 v8
    }

    fn must_not_optimize(p: u64) -> u64 {
        entry(p: u64):
        v0 = const u64 100
        v2 = cmp eq v0 p
        cbr v2, get_0_block0(), get_0_block0()

        get_0_block0():
        v5 = const u64 1
        v6 = add v5, p
        ret u64 v6
    }
}
