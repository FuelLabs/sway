script {
    entry fn main(a: u64, b: u64) -> () {
        entry(a: u64, b: u64):
        v5 = add a, b
        v6 = const u64 0
        br while(v6, v5)

        while(v3: u64, v4: u64):
        v8 = cmp lt v3 v4
        cbr v8, while_body(), end_while()

        while_body():
        v10 = add a, b
        v11 = const u64 1
        v12 = add v3, v11
        br while(v12, v10)

        end_while():
        v14 = const unit ()
        ret () v14
    }
}
