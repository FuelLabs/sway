script {
    pub entry fn __entry() -> __ptr never {
        local u64 _result

        entry():
        v10v1 = call main()
        v11v1 = get_local __ptr u64, _result
        store v10v1 to v11v1
        v134v1 = get_local __ptr u64, _result
        v21v1 = const u64 8
        retd v134v1 v21v1
    }

    entry_orig fn main() -> u64 {
        entry():

        v2 = const u64 2
        v20 = call switcher(v2)

        v3 = const u64 3
        v30 = call switcher(v3)
        v31 = add v30, v20

        v4 = const u64 4
        v40 = call switcher(v4)
        v41 = add v40, v31

        ret u64 v41
    }

    fn switcher(v: u64) -> u64 {
        entry(v: u64):
        switch v, [2: block2(), 3: block3(), 4: block4()]

        block2():
        v2 = const u64 2
        ret u64 v2

        block3():
        v3 = const u64 3
        ret u64 v3

        block4():
        v4 = const u64 4
        ret u64 v4
    }
}
